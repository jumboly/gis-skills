# Auto-detect text files and normalize line endings
* text=auto

# Python
*.py text diff=python

# Markdown
*.md text diff=markdown

# Shell scripts
*.sh text eol=lf

# PowerShell (Windows)
*.ps1 text eol=crlf

# GIS binary formats
*.shp binary
*.dbf binary
*.shx binary
*.prj binary
*.cpg binary
*.qix binary
*.sbn binary
*.sbx binary
*.gpkg binary
