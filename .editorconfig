root = true

[*]
charset = utf-8
end_of_line = lf
trim_trailing_whitespace = true
insert_final_newline = true

[*.py]
indent_style = space
indent_size = 4

[*.md]
trim_trailing_whitespace = false

[*.sh]
indent_style = space
indent_size = 4

[*.ps1]
indent_style = space
indent_size = 4

[*.json]
indent_style = space
indent_size = 2
